{
  "name": "signalk-sailsense",
  "version": "1.3.0",
  "description": "Connects to a SailSense Hub, and publishes raw data to SignalK. Additionally exposes a web application for viewing the data and manipulating circuit breakers.",
  "main": "index.js",
  "scripts": {
    "test": "node --test test/index.test.js"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-hardware",
    "signalk-category-utility"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukeescude/signalk-sailsense.git"
  },
  "author": "Luke Escude",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "index.js",
    "CHANGELOG.md",
    "public",
    "screenshots",
    "icon.png"
  ],
  "signalk": {
    "displayName": "SailSense Hub",
    "appIcon": "icon.png",
    "recommends": [
      "signalk-navico-embedder"
    ],
    "screenshots": [
      "./screenshots/home.png",
      "./screenshots/power.png",
      "./screenshots/breakers.png",
      "./screenshots/tanks.png",
      "./screenshots/lights.png",
      "./screenshots/mobile_1.png",
      "./screenshots/mobile_2.png"
    ]
  },
  "dependencies": {
    "mqtt": "^5.15.1"
  }
}
